# OpenAI
OPENAI_API_KEY=sk-...

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase MCP (Cursor) — export these in your shell profile (~/.zshrc)
# Token: https://supabase.com/dashboard/account/tokens
# Project ref: the subdomain from your Supabase URL (xxxxx in xxxxx.supabase.co)
SUPABASE_ACCESS_TOKEN=sbp_...
SUPABASE_PROJECT_REF=xxxxx

# Gmail (use a dedicated demo account; create an App Password)
GMAIL_USER=ai.recruiter.demo@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_SMTP_HOST=smtp.gmail.com
# SMTP port: 587 (STARTTLS, Railway-friendly default) or 465 (implicit TLS).
GMAIL_SMTP_PORT=587

# Worker
WORKER_POLL_INTERVAL_MS=30000
# Generate one with:  node -e "console.log(crypto.randomUUID())"
WORKER_SHARED_SECRET=change-me

# Scoring
MAX_OUTREACH_ROUNDS=3

# Analytics — password to unlock token usage & cost on /analytics (5× click the chart icon)
ANALYTICS_UNLOCK_PASSWORD=password

# App URL — public base URL used to build candidate/interviewer links
# (scheduling responses, reschedule links, Slack approval buttons).
# Use your deployed URL in production, e.g. https://talentscout.example.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Slack — interviewer interview-approval requests via DM (optional).
# Create a Slack app (https://api.slack.com/apps), add the `chat:write` and
# `users:read.email` bot scopes, install it to your workspace, and copy the Bot
# User OAuth Token (xoxb-...). The bot DMs each interviewer directly: it uses a
# stored slack_user_id if present, otherwise resolves it from the interviewer's
# email (users:read.email) and caches it. SLACK_CHANNEL_ID is only a last-resort
# fallback if no DM target can be found. SLACK_SIGNING_SECRET is needed only to
# enable the in-place interactive buttons (POST /api/slack/actions); the default
# URL-button flow works without it.
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=

# Google Stitch MCP (Cursor) — https://stitch.googleapis.com/mcp
STITCH_API_KEY=your-stitch-api-key
